(deflisten activewindow :initial "..." "hyprman -f activewindow")

(defvar windowIcons 
  `{
     "generic": "¯¡┐",
     "spotify": "´å╝",
     "mpv": "´ì«",
     "firefox": "´ë®",
     "chromium": "´ë¿",
     "zen": "¯Ø½",
