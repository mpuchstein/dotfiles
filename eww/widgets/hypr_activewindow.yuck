(defwidget windowIcon []
  (image
    :limit-width 10
    :icon-size: 12
    :icon {activewindow.data.window_class}))

(defwidget windowTitle []
  (label 
    :class "windowIcon"
    :limit-width 10
    :text {activewindow.data.window_title}))

(defwidget active_window []
  (box 
    :class "activewindow"
    :halign "center"
    :valign "center"
    :spacing 1
    (windowIcon) (windowTitle)))
